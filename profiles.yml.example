dp_shelf_warmers:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: <fill in>
      user: <fill in>
      password: <fill in>
      role: <fill in>
      database: DP_SHELF_WARMERS
      warehouse: <fill in>
      # Profile schema is the internal layer (staging, intermediate). The output
      # port model overrides this via config(schema='op_v1'), landing in
      # DP_SHELF_WARMERS_OP_V1 — the only schema the data contract / integration
      # scan target.
      schema: dp_shelf_warmers
      threads: 4
