dp_shelf_warmers:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: <fill in>
      user: <fill in>
      password: <fill in>
      role: <fill in>
      database: DP_SHELF_WARMERS
      warehouse: <fill in>
      # Profile schema is dbt's fallback default; with the `generate_schema_name`
      # macro override in macros/get_custom_schema.sql, each layer overrides it:
      #   staging/ + intermediate/  →  internal_dp_shelf_warmers
      #   output_ports/v1/<table>   →  op_shelf_warmers_v1   (only public surface)
      schema: dp_shelf_warmers
      threads: 4
